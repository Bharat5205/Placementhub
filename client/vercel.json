{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://placementhub-backend-qpwl.onrender.com/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://placementhub-backend-qpwl.onrender.com/auth/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://placementhub-backend-qpwl.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!assets/|favicon.ico|logos/|student_avatar.png|coordinator_avatar.png|campus_bg.png).*)",
      "destination": "/index.html"
    }
  ]
}
