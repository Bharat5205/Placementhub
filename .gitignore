# ==========================================
# PlacementHub Root Git Ignore
# ==========================================

# ── Dependency Directories ────────────────
node_modules/
**/node_modules/

# ── Environment & Secrets ──────────────────
# Ignore all environment files containing sensitive keys
.env
.env.local
.env.development
.env.production
.env.test
*.env
**/.env
**/.env.*

# Keep example files tracked to document required env variables
!.env.example
!server/.env.example

# ── Build & Compilation Outputs ────────────
dist/
build/
.next/
out/
dist-ssr/
**/dist/
**/build/

# ── Logs & Debugging ──────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Caches ────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.vite/

# ── IDE & Editor Settings ──────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swo
*~

# ── OS Generated Files ─────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Dynamic Uploads ────────────────────────
# Exclude dynamically uploaded company logos and JDs, but track the folder structure
server/src/uploads/*
!server/src/uploads/.gitkeep
